<Window x:Class="ProlificProvisioner.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ProlificProvisioner.App.ViewModels"
        Title="Prolific Cable Provisioning"
        Width="1100" Height="700" WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBackgroundBrush}"
        FontFamily="Segoe UI">
    <DockPanel Margin="24">

        <!-- Top bar -->
        <Grid DockPanel.Dock="Top" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Prolific Cable Provisioning" FontSize="30" FontWeight="Bold"
                       Foreground="{StaticResource PrimaryTextBrush}"/>
            <Button Grid.Column="1" Content="Settings" Click="OpenSettings_Click"
                    Style="{StaticResource ActionButtonStyle}" Background="#2A2A2A" Foreground="White"
                    BorderBrush="#3A3A3A"/>
        </Grid>

        <!-- Unresolved-device banner -->
        <Border DockPanel.Dock="Top" Background="#3A2E00" BorderBrush="#F2A600" BorderThickness="1"
                CornerRadius="6" Padding="14" Margin="0,0,0,16"
                Visibility="{Binding UnresolvedDeviceNotice, Converter={StaticResource NullToCollapsedConverter}, FallbackValue=Collapsed}">
            <Grid>
                <TextBlock Text="{Binding UnresolvedDeviceNotice}" Foreground="#F2A600" TextWrapping="Wrap"
                           FontSize="14" Margin="0,0,80,0"/>
                <Button Content="Dismiss" Command="{Binding DismissUnresolvedNoticeCommand}"
                        HorizontalAlignment="Right" Padding="10,4" Background="Transparent"
                        Foreground="#F2A600" BorderBrush="#F2A600"/>
            </Grid>
        </Border>

        <!-- Two port cards -->
        <UniformGrid Columns="2" Rows="1">
            <ContentControl Content="{Binding DispenseHead}" ContentTemplate="{StaticResource PortCardTemplate}" Margin="0,0,12,0"/>
            <ContentControl Content="{Binding Printer}" ContentTemplate="{StaticResource PortCardTemplate}" Margin="12,0,0,0"/>
        </UniformGrid>
    </DockPanel>
</Window>
