<Application x:Class="ProlificProvisioner.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ProlificProvisioner.App.Converters"
             xmlns:vm="clr-namespace:ProlificProvisioner.App.ViewModels"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <SolidColorBrush x:Key="StatusIdleBrush" Color="#9AA0A6"/>
            <SolidColorBrush x:Key="StatusInProgressBrush" Color="#F2A600"/>
            <SolidColorBrush x:Key="StatusSuccessBrush" Color="#1E8E3E"/>
            <SolidColorBrush x:Key="StatusFaultBrush" Color="#D93025"/>
            <SolidColorBrush x:Key="CardBackgroundBrush" Color="#1E1E1E"/>
            <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#121212"/>
            <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F1F1F1"/>
            <SolidColorBrush x:Key="SecondaryTextBrush" Color="#B0B0B0"/>

            <conv:NullToVisibilityConverter x:Key="NullToCollapsedConverter"/>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

            <Style TargetType="Button" x:Key="ActionButtonStyle">
                <Setter Property="Padding" Value="18,10"/>
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Margin" Value="6,0"/>
                <Setter Property="Cursor" Value="Hand"/>
            </Style>

            <!--
                One card template drives both COM1 (Dispense Head) and COM2 (Printer)
                slots, bound to a PortStatusViewModel. Kept deliberately simple/high-contrast
                so a line worker can read status at a glance without close reading.
            -->
            <DataTemplate x:Key="PortCardTemplate" DataType="{x:Type vm:PortStatusViewModel}">
                <Border Background="{StaticResource CardBackgroundBrush}" CornerRadius="12" Padding="28">
                    <StackPanel>
                        <TextBlock Text="{Binding RoleTitle}" FontSize="24" FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryTextBrush}"/>
                        <TextBlock Text="{Binding TargetPort}" FontSize="16"
                                   Foreground="{StaticResource SecondaryTextBrush}" Margin="0,2,0,20"/>

                        <Ellipse Width="22" Height="22" Fill="{Binding StatusBrush}" HorizontalAlignment="Left" Margin="0,0,0,14"/>

                        <TextBlock Text="{Binding StepText}" FontSize="20" FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryTextBrush}" TextWrapping="Wrap" Margin="0,0,0,10"/>

                        <TextBlock Text="{Binding FailureReason}" FontSize="14" Foreground="{StaticResource StatusFaultBrush}"
                                   TextWrapping="Wrap" Margin="0,0,0,14"
                                   Visibility="{Binding FailureReason, Converter={StaticResource NullToCollapsedConverter}}"/>

                        <!-- Success: confirm the cable got labeled -->
                        <StackPanel Visibility="{Binding IsSuccess, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Button Content="Confirm Labeled" Command="{Binding ConfirmLabeledCommand}"
                                    Style="{StaticResource ActionButtonStyle}" HorizontalAlignment="Left"
                                    Background="{StaticResource StatusSuccessBrush}" Foreground="White" BorderThickness="0"/>
                        </StackPanel>

                        <!-- Cable fault: retry or scrap -->
                        <StackPanel Orientation="Horizontal" Visibility="{Binding IsFault, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Button Content="Retry" Command="{Binding RetryCommand}"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Background="{StaticResource StatusInProgressBrush}" Foreground="Black" BorderThickness="0"/>
                            <Button Content="Mark Cable Defective" Command="{Binding MarkDefectiveCommand}"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Background="{StaticResource StatusFaultBrush}" Foreground="White" BorderThickness="0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
