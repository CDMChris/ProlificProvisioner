<Window x:Class="ProlificProvisioner.App.Views.LearnPortsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Learn Fixture Ports" Width="640" Height="480" WindowStartupLocation="CenterOwner"
        Background="{StaticResource WindowBackgroundBrush}" FontFamily="Segoe UI">
    <DockPanel Margin="20">
        <TextBlock DockPanel.Dock="Top" TextWrapping="Wrap" Margin="0,0,0,16"
                   Foreground="{StaticResource PrimaryTextBrush}" FontSize="14">
            Plug a cable into each fixture slot one at a time. Every Prolific device
            currently connected shows below by its physical USB location — tag each
            one as Dispense Head (COM1) or Printer (COM2). This mapping is what lets
            the app tell the two cables apart even though they report the same hardware ID.
        </TextBlock>

        <Button DockPanel.Dock="Bottom" Content="Done" Click="Done_Click" HorizontalAlignment="Right"
                Style="{StaticResource ActionButtonStyle}" Background="#2A2A2A" Foreground="White"
                Margin="0,16,0,0"/>

        <ListView ItemsSource="{Binding DetectedDevices}" Background="Transparent" BorderThickness="0">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Background="{StaticResource CardBackgroundBrush}" CornerRadius="8" Padding="14" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="{Binding LocationPath}" FontWeight="Bold" FontSize="14"
                                       Foreground="{StaticResource PrimaryTextBrush}"/>
                            <TextBlock Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" Margin="0,2,0,10">
                                <Run Text="Currently mapped to: "/>
                                <Run Text="{Binding CurrentRole, FallbackValue='(not yet assigned)'}"/>
                            </TextBlock>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Assign as Dispense Head (COM1)" Command="{Binding AssignDispenseHeadCommand}"
                                        Padding="10,6" Margin="0,0,8,0" Background="#2A2A2A" Foreground="White" BorderThickness="0"/>
                                <Button Content="Assign as Printer (COM2)" Command="{Binding AssignPrinterCommand}"
                                        Padding="10,6" Background="#2A2A2A" Foreground="White" BorderThickness="0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </DockPanel>
</Window>
