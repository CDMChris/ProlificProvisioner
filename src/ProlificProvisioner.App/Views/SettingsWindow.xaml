<Window x:Class="ProlificProvisioner.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings (Engineering)" Width="640" Height="460" WindowStartupLocation="CenterOwner"
        Background="{StaticResource WindowBackgroundBrush}" FontFamily="Segoe UI">
    <StackPanel Margin="24">
        <TextBlock Text="Fixture &amp; Driver Configuration" FontSize="20" FontWeight="Bold"
                   Foreground="{StaticResource PrimaryTextBrush}" Margin="0,0,0,4"/>
        <TextBlock Text="Not for line-worker use — changes here affect every unit provisioned." FontSize="12"
                   Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,20"/>

        <Button Content="Learn Fixture Ports…" Click="LearnPorts_Click" HorizontalAlignment="Left"
                Style="{StaticResource ActionButtonStyle}" Background="#2A2A2A" Foreground="White" Margin="0,0,0,20"/>

        <TextBlock Text="Dispense-head known-good driver (.inf)" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,4"/>
        <TextBox x:Name="DispenseHeadInfBox" Margin="0,0,0,14" Padding="6"/>

        <TextBlock Text="Printer driver (.inf, 2026 release)" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,4"/>
        <TextBox x:Name="PrinterInfBox" Margin="0,0,0,14" Padding="6"/>

        <TextBlock Text="Per-step timeout (seconds)" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,4"/>
        <TextBox x:Name="TimeoutBox" Width="100" HorizontalAlignment="Left" Margin="0,0,0,14" Padding="6"/>

        <TextBlock Text="Max automatic retries before flagging a Cable Fault" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,4"/>
        <TextBox x:Name="MaxRetriesBox" Width="100" HorizontalAlignment="Left" Margin="0,0,0,20" Padding="6"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Click="Cancel_Click" Padding="14,8" Margin="0,0,8,0" Background="#2A2A2A" Foreground="White" BorderThickness="0"/>
            <Button Content="Save" Click="Save_Click" Padding="14,8" Background="{StaticResource StatusSuccessBrush}" Foreground="White" BorderThickness="0"/>
        </StackPanel>
    </StackPanel>
</Window>
